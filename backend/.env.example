# UAG Backend — Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────
APP_ENV=development
PORT=8080

# ─── Database (PostgreSQL) ────────────────────────
DATABASE_URL=postgres://uag:secret@localhost:5432/uag_db?sslmode=disable

# ─── Redis ───────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=168

# ─── Stripe ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── File Uploads ─────────────────────────────────
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:8080

# ─── Email (SMTP) ─────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@uag.app

# ─── Referral System ─────────────────────────────
REFERRAL_SIGNUP_CREDIT=0.50
REFERRAL_TIP_PERCENTAGE=0.10
